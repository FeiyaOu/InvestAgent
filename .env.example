# InvestAgent — 环境变量配置模板
# 复制本文件为 .env，填入真实值，不要提交 .env 到 git

# ============================================================
# 必填 — Qwen LLM（驱动全部节点的 LLM 推理）
# 获取地址：https://dashscope.console.aliyun.com/
# ============================================================
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ============================================================
# 数据模式开关
# true  = 调用真实 AKShare 数据（需要网络）
# false = 使用预设 mock 数据（离线演示 / 面试应急）
# ============================================================
USE_REAL_DATA=true

# ============================================================
# 可选 — LangFuse（追踪每阶段 LLM 调用延迟和 token 消耗）
# 获取地址：https://cloud.langfuse.com/
# ============================================================
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ============================================================
# 可选 — LangSmith（评估数据集管理和批量测试）
# 获取地址：https://smith.langchain.com/
# ============================================================
LANGSMITH_API_KEY=lsv2-your-key-here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=InvestAgent
